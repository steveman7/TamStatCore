вҲҮ Doit_Anova
     
     вҚқ   use Anova
 ##.Stuff.anova_dataвҶҗ##.Stuff.MakeData_Anova 2
 nsaвҶҗ##.Stats.Anova(,anova_data)(вҚҙanova_data)
     
     вҚқ   compare with MOST
 #.MOST.CLEAN
 #.MOST.START
 #.MOST.GETDA,[1.5],##.Stuff.anova_data
 #.MOST.ANOVA 1(вҚҙ##.Stuff.anova_data)
     
 :Return
вҲҮ

вҲҮ Doit_Pcomps;pdata
     
 :If 0=вҺ•NC'##.Stuff.DEFINE_pdata'
     ##.Stuff.pdataвҶҗ##.Stuff.MakePData
     вҺ•SE.V2F_code.V2F'pdata'
 :EndIf
     
 ##.Stuff.DEFINE_pdata
     
 nspвҶҗ##.Stats.PrincipleComponents ##.Stuff.pdata
     
 #.MOST.CLEAN
 #.MOST.START
 #.MOST.MOSTвҲҶDATAвҶҗ##.Stuff.pdata
 #.MOST.PCOMV 1 20 1 1 1
     
 :Return
вҲҮ

вҲҮ Doit_Regress err;rdata;names;zz
     
 rdata names acвҶҗ##.Stuff.MakeDataR err
 rdataвҶҗвҶ“[1]rdata
 nsrвҶҗnames ##.Stats.RegressMultipleLinear(вҠғвҢҪrdata)(ВҜ1вҶ“rdata)
     
 вҲҶQL nsr.(X[;2]Yhat)
 вҲҶQP nsr.(X[;2]Y)
 вҚҺвҺ•вҶҗ'         вҶ‘nsr.(Actual_Coeffs C_apl Coeffs)'
     
 :Return
вҲҮ

вҲҮ Doit_SM_Regress;io;fixed
     
 ##.Stuff.DEFINE_SM_fixed
 ##.Stuff.DEFINE_SM_HEAD
 fixedвҶҗвҶ“[1]1,SM_fixed
 rnsвҶҗ((вҠӮ7вҠғSM_HEAD),((вҠӮ'Const'),SM_HEAD[(вҚі23)~7]))##.Stats.RegressMultipleLinear(8вҠғfixed)(fixed[(вҚі24)~8])
     
 ioвҶҗвҚӢ(rns.Yhat)
 'smr'вҲҶQP(rns.Yhat)[io]
 'smr'вҲҶQP(rns.Y)[io]
 'smr'вҲҶQT'data in sequential Yhat sorted order' 'B=Yhat  R=shoe' 'All variable regression'
     
 :Return
вҲҮ

вҲҮ Doit_SM_Regress_MOST
     
 ##.Stuff.DEFINE_SM_fixed
 ##.Stuff.DEFINE_SM_HEAD
 #.MOST.CLEAN
 #.MOST.START
 #.MOST.GETDA SM_fixed
 #.MOST.MOSTвҲҶвҲҶV_NAMESвҶҗSM_HEAD
 nsMregвҶҗ#.MOST.REGRE((вҚі23)~7)7 0 0 0 0 1 1 1 1 0 1
     
 :Return
