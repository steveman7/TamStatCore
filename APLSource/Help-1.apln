    вИЗ ZвЖР{FN}DOCSYN X;XX;B;V;L;AA;I;Q;U;BB;KBD;EKBD;VAR;EVAR
      вНЭ Document Syntax
      вНЭBвЖРXвИК' _вИЖ',вОХD,AAвЖРвОХA,#.USER.lowercase вОХA
      BвЖРXвИК' _вИЖ',вОХD,AAвЖРвОХA,вОХC вОХA
      XвЖР(вИК((0 1 0)1)[B])\X              вНЭ Find non-alphanumeric data
      XXвЖР{(' 'вЙ†вНµ)вКВвНµ},X                  вНЭ Tokenize data
      UвЖР'_'=IвЖРвЖС¬®XX                      вНЭ Get first characters
      XXвЖРUвЖУ¬®XX
      VвЖР(~XXвИКвКВFN)вИІIвИКAA                  вНЭ Identify variables
      LвЖР(~V)вИІ~IвИК'()[]{}вИ£'               вНЭ Identify literals
      QвЖРI=''''                          вНЭ Identify quotes
      KBDвЖР'<kbd><b><span style="font-size:15.0pt;font-family:Arial">'
      EKBDвЖР'</span></b></kbd>'
      VARвЖР'<span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial"><var>'
      EVARвЖР'</var><i> </i></span>'
      (U/XX)вЖР{'<U>',вНµ,'</U>'}¬®U/XX      вНЭ Underscore defaults
      вНЭ(V/XX)вЖР{'</B><VAR>',вНµ,'</VAR><B>'}¬®V/XX  вНЭ Make variables italic
      (V/XX)вЖР{VAR,вНµ,EVAR}¬®V/XX  вНЭ Make variables italic
      вНЭ(L/XX)вЖР{'<STRONG><KBD>',вНµ,'</KBD></STRONG>'}¬®L/XX  вНЭ Make it boldface
      (L/XX)вЖР{KBD,вНµ,EKBD}¬®L/XX  вНЭ Make it boldface
      BвЖР0,2вИІ/LвИ®V
      XXвЖР(BBвЖРвИК(1(0 1))[B])\XX
      BвЖР{(¬ѓ1вМљвНµвН≤вЙ†\вНµ)вИІ(1вМљвНµвЙ§вЙ†\вНµ)}BB\Q
      вНЭZвЖР'<br> . . . ',вЖС,/B/XX
      ZвЖР'<p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:'
      Z,вЖР'18.0pt;font-family:Arial">Syntax:</span></b></p>'
      Z,вЖР'<blockquote>'
      Z,вЖР'<p style="margin-left: 0"><kbd><span style="font-size:15.0pt;font-family:Arial">'
      Z,вЖРвЖС,/B/XX
      Z,вЖР'</span></p></blockquote>'
      ZвЖРss Z'вИ£' '&#166;'
      ZвЖРss Z'вЖР' '&#8592;'
