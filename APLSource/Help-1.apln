      :EndIf
      Z,вЖР'Expression:<span style="mso-spacerun: yes">&nbsp;&nbsp;'
      вНЭZ,вЖР'</span><b>',X,'<br>'
      Z,вЖР'</span></span><code><b>'
      Z,вЖР'<span style="font-size:15.0pt;font-family:APL385 Unicode;color: green">'
      Z,вЖРX,'</span></b></code>'
      вНЭZ,вЖР'</span><b><code><span style="font-size:15.0pt;font-family:APL385 Unicode"',X,'</span></code><br>'
      Z,вЖР'<span style="mso-spacerun: yes">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></b></span></code>'
      :If I>0
          Z,вЖР'<span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;'
          Z,вЖР'font-family:Arial">Result:<span style="mso-spacerun: yes">&nbsp;&nbsp;&nbsp;&nbsp;'
          вНЭZ,вЖР'font-family:APL385 Unicode">Result:<span style="mso-spacerun: yes">&nbsp;&nbsp;&nbsp;&nbsp;'
          Z,вЖР'</span></span><code><b>'
          Z,вЖР'<span style="font-size:15.0pt;font-family:APL385 Unicode">'
          Z,вЖРR,'</span></b></code>'
      :EndIf
      Z,вЖР'</p>'
    вИЗ

      GetUserFunctionCategoryвЖР{
          xвЖР{'&'вЙ°вЖСвНµ:'вИЖ',1вЖУвНµ вЛД вНµ}вНµ
          fooвЖР#.USER.ljust #.USER.вОХCR x
          typeвЖРfoo[1;1]
     вНЭ     1вКГ,(typeвНЈFunctionCategoryList[;0])вМњFunctionCategoryList[;1]
          indexвЖРFunctionCategoryList[;0]вН≥type
          вЖСFunctionCategoryList[index;1]
      }

      GetUserFunctionListвЖР{
          FвЖР(вКВ[1]#.USER.вОХNL 3 4)~¬®' '
          FвЖР{'вИЖ'=вЖСвНµ:#.UDF.Prefix,1вЖУвНµ вЛД вНµ}¬®F      вНЭ SMM 10/10/01
          F
      }

      dbrвЖР{
          0=вЖСвНівНµ:вНµ
          DEB вНµ
      }

    вИЗ ZвЖРljust Y
     вНЭвНЮ Left justify
     вНЭвИЗ Move text to the leftmost position.
     вНЭвИЗ Leading blanks are moved to the end of the field
     вНЭвНХ ljust TextField
     вНЭвНµ TextField TFWn Raw Data
     вНЭвЖР NewField TFWn  Formatted data; width remains the same
     вНЭвНО 'Steve    ' вЖР ljust '   Steve '
     вНЭвНО ljust PROPTYPE
      ZвЖР(+/вИІ\' '=Y)вМљY
    вИЗ

    вИЗ ZвЖРrjust Y
     вНЭвНЮ Right justify
     вНЭвИЗ Move text to the rightmost position.
     вНЭвИЗ Trailing blanks are moved to the beginning of the field
     вНЭвНХ rjust TextField
     вНЭвНµ TextField TFWn Raw Data
     вНЭвЖР NewField TFWn  Formatted data; width remains the same as input field
     вНЭвНО '   Steve' вЖР rjust 'Steve   '
      ZвЖРвМљljustвМљY
    вИЗ

      ssвЖР{                               вНЭ Simulates xutils.ss
          вНЇвЖР0 0                          вНЭ Simple replaces only, no regex
          uc brвЖР2вЖСвНЇ,0                    вНЭ Uppercase, boolean result
          t fвЖР,¬®{uc:CAP¬®вНµ вЛД вНµ}2вЖСвНµ    вНЭ Text, from, replacement
          3=вНівНµ:(0вКГвНµ)ss_cap t f(2вКГвНµ)  вНЭ 3 items, find and replace
          вНЭ bвЖРfвНЈt                        вНЭ Phil's find, to remove overlapping
          вНЭ findвЖР{(вНівНЇ)вЖУвМљ~вКГ(¬ѓ1+вНівНЇ){(вНЇвИ®вНЇвНЇ>+/вИІ\вНµ),вНµ}/вМљ(вНЇ=вНЇ),~вНЇвНЈвНµ}
          findвЖР{(вНівНЇ){вНµ\вНЇ{вНµвИКвКГвНЇ{вНµ,вНЇ/вН®вНЇвЙ•вНЇвНЇ+вМИ/вНµ}/вМљ(-вНЇ),вНµ}вНµ/вН≥вНівНµ}вНЇвНЈвНµ} вНЭ Faster
          bвЖРf find t
          br:b                           вНЭ Boolean result
          1+b/вН≥вНіb                        вНЭ Integer, вОХIO 0
      }

      ss_capвЖР{вОХMLвЖР3                       вНЭ Approx alternative to xutils' ss.
          ucвЖРвНЇ                            вНЭ UnCapped source
          srce find replвЖР,¬®вНµ              вНЭ Source, find and replace vectors.
          iвЖР{+\findвНЈвНµ}find,srce           вНЭ Partitioned at find points.
          cvexвЖРiвКВfind,uc                  вНЭ Partitioned at find points.
          (вНіrepl)вЖУвИК{repl,(вНіfind)вЖУвНµ}¬®cvex  вНЭ Collected with replacements.
      }

      tpathвЖР{
          iвЖР{(вНі,вНµ)-1+(вМљ,вНµ)вН≥вН≥1+вМИ/вНµ}¬®,\вНµ вНЭ Get path indices
          вЖС¬®{вНЇ,'\',вНµ}/¬®i{вНµ[вНЇ]}¬®вКВвНЇ      вНЭ Assemble path names
      }

    where1вЖР{{вНµ/вН≥вНівНµ}вНЇвНЈвНµ}

    вИЗ ZвЖР{X}word Y;F;D;N;B;I;W;вОХML
     вНЭвНЮ Word
     вНЭвИЗ Extract a word or string from a character field.
     вНЭвИЗ NOTE: If the delimiter is blank, (ie: ' ')
     вНЭвИЗ then consecutive delimiters as treated as one unless overridden
     вНЭвИЗ by left argument
     вНЭвНХ [0вИ£1вИ£2] word TextField Delimiter Position
     вНЭвНЇ 0 = Treat Consecutive Delimiters separately
     вНЭвНЇ 1 = Treat Consecutive Delimiters as one
     вНЭвНЇ 2 = Treat only blanks as consecutive delimiters (default)
     вНЭвНµ TextField TF Raw data
     вНЭвНµ Delimiter TC e.g. ','
     вНЭвНµ Position  IC>0 e.g. 2 = get second word
     вНЭвЖР NewField  TF Extracted data
     вНЭвНО word ADDRESS ',' N    вНЭ Extract the nth word from the beginning
     вНЭвНО word ADDRESS ',' (-N) вНЭ Extract the nth word from the end
      :If 0=вОХNC'X' вЛД XвЖР2 вЛД :EndIf
      (F D N)вЖРY
      IвЖР¬ѓ1+|N
      вНЭ:If D=' '       вНЭ Treat Consecutive delimiters as one
      :If (X=1)вИ®(X=2)вИІD=' '
        вНЭ  FвЖРвКВ[1]F     вНЭ
          FвЖРвЖУF
          FвЖР(DвЙ†F)вКВ¬®F  вНЭ
          FвЖРNвЖС¬®F
          ZвЖРвКГвЖС¬®(-√ЧN)вЖС¬®F
      :Else           вНЭ
          FвЖРD,F
          BвЖРD=F
         вНЭFвЖРвКВ[1]F
          FвЖРвЖУF
         вНЭBвЖРвКВ[1]B
          BвЖРвЖУB
          вОХMLвЖР0 вЛД FвЖРBвКВ¬®F вЛД вОХMLвЖР3
          FвЖРNвЖС¬®F
          ZвЖРвКГвЖС¬®(-√ЧN)вЖС¬®F
         вНЭZвЖР0 1вЖУZ
          ZвЖР1вЖУ[¬ѓ1+вНівНіZ]Z
      :EndIf
    вИЗ


