    вИЗ ZвЖРDOCTERM R;NAME;TYPE;DESC;DEF;OPT;B;I;FF
      вНЭTYPE:
      (NAME TYPE DESC)вЖР3вЖС{((~B)вИ®2<+\BвЖР' '=вНµ)вКВвНµ}dbr R
      OPTвЖР'['=вЖСNAME
      (NAME DEF)вЖР2вЖС{(~вНµвИК'[]вЖР')вКВвНµ}NAME
     вНЭ ZвЖР'<LI><VAR>',NAME,' </VAR> - ',OPT/'<I>(Optional)</I> '
      ZвЖР'<var><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
      Z,вЖРNAME,OPT/' (Optional)'
      Z,вЖР'</span></var><span style="font-size:15.0pt;mso-bidi-font-size:'
      Z,вЖР'18.0pt;font-family:Arial"> - '
      Z,вЖР'<span style="mso-spacerun: yes">&nbsp; </span>'
      :If ' 'вИ®.вЙ†DESC вЛД Z,вЖРDESC,'; ' вЛД :EndIf
      :Select вЖСTYPE
      :CaseList 'XYZ' вЛД Z,вЖР'Numeric, Real'
      :CaseList 'AB' вЛД Z,вЖР'Boolean:  ',NAME,'вИК{0,1}'
      :CaseList 'CD' вЛД Z,вЖР'Character'
      :Case 'E' вЛД Z,вЖР'Nested'
      :CaseList 'MN' вЛД Z,вЖР'Positive Integer: ',NAME,'вИК{1,2,3,...}'
      :Case 'I' вЛД Z,вЖР'Non-negative Integer: ',NAME,'вИК{0,1,2,...}'
      :Case 'J' вЛД Z,вЖР'Integer: ',NAME,'вИК{...¬ѓ2,¬ѓ1,0,1,2,...}'
      :CaseList 'P' вЛД Z,вЖР'Probability: (0вЙ§',NAME,'вЙ§1)'
      :CaseList 'Q' вЛД Z,вЖР'Probability: (0<',NAME,'<1)'
      :Case 'R' вЛД Z,вЖР'Unit (-1вЙ§',NAME,'вЙ§1)'
      :CaseList 'ST' вЛД Z,вЖР'Non-negative Real: (',NAME,'вЙ•0)'
      :CaseList 'UV' вЛД Z,вЖР'Positive Real:  (',NAME,'>0)'
      :Case 'W' вЛД Z,вЖР'Namespace'
      :CaseList 'fgh' вЛД Z,вЖР'Function; '
      :Case 'o' вЛД Z,вЖР'Operator: '
      :EndSelect
      IвЖР'svmanDSRL 'вН≥вЖС1вЖУTYPE
      :If 'o'=вЖСTYPE
          :If 'D'=вЖС1вЖУTYPE
              Z,вЖР'<b>prob|critVal|randVar|theoretical</b>'
          :Else
              Z,вЖР'confInt|hypothesis'
          :EndIf
      :Else
          FFвЖР'Distribution' 'Summary' 'Relational: <b>lt|вЙ§|=|вЙ•|gt|вЙ†|between|outside|include</b>' 'Logical: <b>вИІ|вИ®|=|вЙ†|~|вН≤|вН±</b>'
          Z,вЖР' ',IвКГ'Scalar' 'Vector' 'Matrix' 'Array' 'Nested',FF,вКВ''
      :EndIf
     
  
      :If ' 'вИ®.вЙ†DEF вЛД Z,вЖР' Default = ',DEF вЛД :EndIf
      ZвЖР(-';'=вЖСвМљZ)вЖУZ
     
      Z,вЖР'<br>'
    вИЗ

    вИЗ ZвЖРDOCXMP X;R;C;L;I;J;D
      (I J)вЖРXвН≥'вЖРвНЭ'
      IвЖРI√ЧI<вНіX
      CвЖРdbr(J+1)вЖУX,':'
      RвЖРIвЖСX
      XвЖР(I+1)вЖУJвЖСX
      XвЖРss X' ' '&nbsp;'
      ZвЖР'<p style="margin-left: 0"><code><span style="font-size:15.0pt;font-family:Arial;'
      вНЭ ZвЖР'<p style="margin-left: 0"><code><span style="font-size:15.0pt;font-family:APL385 Unicode;'
      Z,вЖР'mso-bidi-font-weight:bold">'
      :If 0<вНіC
