    вИЗ ZвЖРS DOCNS NS;NL;C;D;B;H1;A;CU;G;TOC;L;UL
      NLвЖРNS.вОХNL 3
      (C D)вЖРвКВ[0]вКГS DOCFN¬®вКВ[1]вЖС,/(вНХNS),'.',вКВNL
      GвЖР{wвЖР#.U.dbr вНµ вЛД '<LI><A HREF="#',w,'">',w,'</A></LI>'}
      LвЖР{wвЖР#.U.dbr вНµ вЛД '<LI><A NAME="',w,'">',w,'</A></LI>'} вНЭCreate link
      ULвЖР{'<UL>',вНµ,'</UL>'}
      :If S
         вНЭ BвЖРвКВ[0]CвИШ.вИКвИ™C    вНЭ Unique Categories
          AвЖР{вНµ[вНЛвКГвНµ]}вИ™C
          BвЖР{вНµвИШ.=вН≥1+вМИ/вНµ}AвН≥C
         вНЭ H1вЖР{'<H1><A NAME="',вНµ,'">',вНµ,' Functions</A></H1>'}¬®CU вНЭ Name and anchor
          H1вЖР{'<H2>',вНµ,' Functions</H2>'}¬®A
          TOCвЖР'<H1>Functions by Category</H1><UL>'
          вНЭTOCвЖР{'<H1><A NAME="',вНµ,'">',вНµ,' Functions</A></H1>'}¬®CU вНЭ Name and anchor
      :Else
          вНЭAвЖР'abcdefghijklmnopqrstuvwxyz'
          AвЖРвОХC вОХA
          BвЖРNL[;0]вИШ.=A
          вНЭH1вЖР{'<H1><A NAME="',вНµ,'">',вНµ,'</A></H1>'}¬®A            вНЭ Name and anchor
          H1вЖР{'<H1>',вНµ,'</H1>'}¬®A
          TOCвЖР'<H0>Functions by Name</H0><UL>'
      :EndIf
      TOC,вЖР(вИКG¬®A),'</UL>'
      вНЭTOC,вЖРULвИК(L¬®A),¬®UL¬®вИК¬®G¬®¬®вКВ[1]¬®(вКВ[0]B)вМњ¬®вКВNL
      TOC,вЖРULвИК(L¬®A),¬®UL¬®вИК¬®G¬®¬®вКВ[1]¬®(вКВ[0]B)вМњ¬®вКВNL
      H1вЖРH1,¬®вКВ'<HR>'
      ZвЖРTOC,вИКH1,¬®(вКВ[0]B)/¬®вКВD
      ZвЖР(вНХNS)Z
