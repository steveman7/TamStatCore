    вИЗ ZвЖРS DOCFN N;GET;FNS;C;G;D;L;R;Y;I;X;CR;CAT;T;CAP;B;IM;Z;OP
     вНЭвИЗ Document a function
     вНЭвИК Text
     вНЭвНЇ Sort method:  0=Alphabetic, 1=By category
     вНЭвНµ Function Name:  Character Vector
     вНЭвЖР 2-item nested vector:
     вНЭвЖР Category name
     вНЭвЖР HTML text string
     вНЭвНО 1 DOCFN 'pv'
     вНЭ ZвЖРHeader вЛД вЖТ0
      NвЖРss N Prefix'вИЖ'
     вНЭ CRвЖР{(+/вИІ\' '=вНµ)вМљвНµ}вОХCR'#.USER.',N   вНЭ Get Cannonical Representation
      CRвЖР{(+/вИІ\' '=вНµ)вМљвНµ}вОХCR'#.TamStat.',N             вНЭ Get Cannonical Representation
      :If 0вИКвНіCR вЛД ZвЖР'' вЛД вЖТ0 вЛД :EndIf       вНЭ Exit if not found or empty
      NвЖР{(1+вМИ/('.'=вНµ)/вН≥вНівНµ)вЖУвНµ}'.',N~' '   вНЭ Strip out function name
     вНЭ N[('вИЖ'=вЖСN)/0]вЖР'@'                  вНЭ Replace вИЖ with @
      CRвЖР0 1вЖУ(0,вИІ\1вЖУCR[;0]='вНЭ')вМњCR       вНЭ Extract comments
      :If вИ®/BвЖРCR[;0]='>'                 вНЭ If continuation character
          CRвЖРвКГ,¬®вКГ¬®(+\~B)вКВBвЖУ¬®вКВ[1]CR       вНЭ Append to end of previous row
      :EndIf                             вНЭ
     вНЭ GETвЖР{0 1вЖУ(вНЇ=вНµ[;0])вМњвНµ}              вНЭ Define GET function
      GETвЖР{(0,вЙҐвНЇ)вЖУ(вНµвНЈвН®вНЇ,' ')[;0]вМњвНµ}              вНЭ Define GET function
      ZвЖР,Header
      Z,вЖР'<h1 style="margin-left: 0"><code><span style="font-size:15.0pt;font-family:Arial">'
      Z,вЖРN,'<span style="mso-spacerun: yes">&nbsp;'
      Z,вЖР'</span><i>-<span style="mso-spacerun: yes">&nbsp; </span></i></span><span style="font-size:15.0pt;font-family:Arial;font-weight:normal">'
      :If ' 'вЙ†вЖСCR                            вНЭ
          :If 'вМК'=вЖСCR                        вНЭ Obsolete
              Z,вЖР'Obsolete</span><span style="font-size:15.0pt;font-family:Arial"><br></span><span style="font-size:15.0pt;font-family:Arial;font-weight:normal">'
              Z,вЖР'Replace with:  ',(1вЖУCR[0;]),'</span></code></h1>'
          :Else
              DвЖР'вИЗ'GET CR                    вНЭ
              :If 0вИКвНіD вЛД DвЖР1вЖУCR[0;] вЛД :EndIf
              CATвЖРdbr,'вИК'GET CR
              Z,вЖРCAT,'</span><span style="font-size:15.0pt;font-family:Arial"><br></span><span style="font-size:15.0pt;font-family:Arial;font-weight:normal">'
              Z,вЖР(,D),'</span></code></h1>'
              :If 0<вЖСвНіXвЖР'вНО'GET CR            вНЭ Get example
                  Z,вЖР'<p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">Examples:<span style="mso-spacerun:'
                  Z,вЖР'yes">&nbsp;&nbsp;</span></span></b></p>'
                  Z,вЖРвИК(DOCXMP¬®вКВ[1]X)
              :EndIf
              :If 0<вЖСвНіIMвЖР,'вОХ'GET CR         вНЭ Image
                  Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  Z,вЖРIM,'<span style="mso-spacerun: yes"> </span></span></b></p> '
                  Z,вЖР'<p><img src="',N,'.gif"></p>' вЛД :EndIf
              :If 0<вЖСвНіTвЖР'#'GET CR            вНЭ Table
                  CAPвЖРT[0;]                  вНЭ
                  TвЖР(' 'вИ®.вЙ†T)вКВTвЖР1вЖУ[0]T       вНЭ
                  TвЖР{#.U.ss вНµ'_' ' '}¬®T      вНЭ Replace _ with blank
                  Z,вЖР#.HTML.TABLE CAP(T[,0;])(1вЖУ[0]T)(0вЖС[0]T)
              :EndIf
              Z,вЖРвИК(вКВN)DOCSYN¬®вКВ[1]'вНХ'GET CR
     
              LвЖР'вНЇ'GET CR                    вНЭ Get left argument
              LвЖРDOCARG L
              :If 0<вЖСвНіL вЛД Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  Z,вЖР'Left Argument: <span style="mso-spacerun: yes"> </span></span></b></p> ',L вЛД :EndIf
              LвЖР'вНЇвНЇ'GET CR
              LвЖРDOCARG L             вНЭ Left Operand Description
              :If 0<вЖСвНіL вЛД Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  LвЖР'<blockquote><p style="margin-left: 0">',(,L),'</blockquote>'
                  Z,вЖР'Left Operand: <span style="mso-spacerun: yes"> </span></span></b></p> ',,L вЛД :EndIf
              OPвЖР'вН•'GET CR          вНЭ Operator Description
              OPвЖРDOCARG OP
              :If 0<вЖСвНіOP вЛД Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  OPвЖР'<blockquote><p style="margin-left: 0">',(,OP),'</blockquote>'
                  Z,вЖР'Operator: <span style="mso-spacerun: yes"> </span></span></b></p> ',,OP вЛД :EndIf
     
              RвЖР'вНµвНµ'GET CR
              RвЖРDOCARG R             вНЭ Right Argument Description
              :If 0<вЖСвНіR вЛД Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  RвЖР'<blockquote><p style="margin-left: 0">',(,R),'</blockquote>'
                  Z,вЖР'Right Operand: <span style="mso-spacerun: yes"> </span></span></b></p> ',,R вЛД :EndIf
              RвЖР'вНµ'GET CR                    вНЭ Get right argument
              RвЖРDOCARG R
              :If 0<вЖСвНіR вЛД Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  Z,вЖР'Right Argument: <span style="mso-spacerun: yes"> </span></span></b></p> ',,R вЛД :EndIf
              YвЖРDOCARG'вЖР'GET CR              вНЭ Get explicit result
              Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
              Z,вЖР'Result: <span style="mso-spacerun: yes"> </span></span></b></p> ',Y вЛД
              :If 0<вЖСвНіDвЖР1вЖУ,' ','вМє'GET CR
                  Z,вЖР' <p style="margin-left: 0"><b><span style="font-size:15.0pt;mso-bidi-font-size:18.0pt;font-family:Arial">'
                  Z,вЖР'See Also: <span style="mso-spacerun: yes"> </span></span></b></p> ',D вЛД
              :EndIf
              Z,вЖР,Footer
          :EndIf
      :Else
          Z,вЖР'</CODE></H1><HR>'
          Z,вЖРвИК,/(1 0вЖУCR),вКВ'<BR>'
      :EndIf
     вНЭ ((Z='вИЖ')/Z)вЖР'@'
      CвЖР{вНµ,(вНµ='&')/'amp'}Prefix
      ZвЖРDEB ss Z'вИЖ'C
      :If 0=вОХnc '#.Boot.ms' 
          'H'вОХWC'htmlrenderer'('html'Z)
      :EndIf
